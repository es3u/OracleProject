<?xml version="1.0" encoding="UTF-8"?>
<api context="/token" name="OracleTokenAPI" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="POST" uri-template="/">
        <inSequence>
            <sequence key="GetOracleTokenSeq"/>
            <redis.set configKey="RedisLocal">
    <redisKey >ORACLE_ACCESS_TOKEN</redisKey>
    <redisValue >{${properties.synapse.ACCESS_TOKEN}}</redisValue>
</redis.set>


            <redis.expire configKey="RedisLocal">
                <redisKey>ORACLE_ACCESS_TOKEN</redisKey>
                <redisSeconds>3540</redisSeconds>
            </redis.expire> 


    <log category="INFO" logMessageID="false" logFullPayload="true">
        <message>BODY BEFORE RESPOND FROM TOKEN API</message>
    </log>




            <respond/>
        </inSequence>
        
        <faultSequence>
        </faultSequence>
       
    </resource>
</api>